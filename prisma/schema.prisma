generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Status {
  DRAFT
  SENT
  VIEWED
  APPROVED
}

model User {
  id        String     @id @default(cuid())
  name      String
  email     String     @unique
  password  String
  createdAt DateTime   @default(now())
  proposals Proposal[]

  @@map("users")
}

model Proposal {
  id    String @id @default(cuid())
  token String @unique

  status Status @default(DRAFT)

  // Company
  companyName  String
  companyPhone String
  companyEmail String
  companyLogo  String?

  // Client
  clientName  String
  clientEmail String
  clientPhone String?
  address     String

  // Salesperson
  salespersonName String
  salespersonRole String

  // System
  systemSizeKw        Float
  panelCount          Int
  panelBrand          String
  panelWattage        Int
  inverterModel       String
  batteryModel        String?
  annualProductionKwh Float

  // Payment options stored as JSON array
  paymentOptions Json

  // Eco metrics
  co2SavedKg           Float
  treesEquivalent      Int
  carDistanceAvoidedKm Float

  // Internal notes
  notes String?

  // Timestamps
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  sentAt     DateTime?
  viewedAt   DateTime?
  approvedAt DateTime?

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  @@map("proposals")
}
